{
  "name": "app",
  "version": "1.0.0",
  "description": "App portable de sqlite con electron",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:portable": "electron-builder --win portable",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.miapp.portable",
    "win": {
      "target": [
        "portable"
      ]
    },
    "directories": {
      "output": "dist"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hore1812/sesiones.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1"
  }
}
